DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=你的密码
DB_NAME=sop_system

# 首次部署（系统中尚无任何可登录账号时）自动创建的管理员
ADMIN_NAME=admin
ADMIN_PASSWORD=admin123

# JWT 登录凭证（生产环境务必修改为随机长字符串）
JWT_SECRET=请替换为随机长字符串
# JWT 有效期，例如 7d、12h、30d
JWT_TTL=7d

# 欧鹭评论下载 Cookie（复制 curl -b 引号内的整段，一行粘贴，不要换行）
# 格式：key1=value1; key2=value2; OALUR_SESSION=...; userId=...
# 含 $ 的 _ga 等字段建议用单引号包裹整段，避免被 dotenv 误解析
# OALUR_COOKIE='enterUrl=https://www.oalur.com/; clientId=xxx; OALUR_SESSION=xxx; userId=xxx; ...'
OALUR_COOKIE=

# Google Trends
# 可选：当当前网络或代理出口被 Google Trends 限制时，复制浏览器访问 trends.google.com 后的 Cookie 整段。
# GOOGLE_TRENDS_COOKIE='NID=...; __Secure-ENID=...'
GOOGLE_TRENDS_COOKIE=
# 可选：不填时会尝试读取 Windows 当前用户代理；也可手动配置，例如 http://127.0.0.1:7890
GOOGLE_TRENDS_PROXY=
# 可选：多个代理，逗号或换行分隔；优先级低于 config/proxies.json
# GOOGLE_TRENDS_PROXIES=http://127.0.0.1:7890,http://127.0.0.1:7891
GOOGLE_TRENDS_PROXIES=
# 可选：代理池配置文件，默认 config/proxies.json（可参考 config/proxies.json.example）
# 代理通过 lack-proxy 仅作用于 trends.google.com 请求，不影响其他 API
# GOOGLE_TRENDS_PROXY_POOL_FILE=config/proxies.json
# 代理被限流后的冷却时间（毫秒），默认 300000
GOOGLE_TRENDS_PROXY_COOLDOWN_MS=300000
GOOGLE_TRENDS_GEO=US
GOOGLE_TRENDS_HL=en-US
GOOGLE_TRENDS_TZ=360
GOOGLE_TRENDS_TIMEOUT_MS=60000
GOOGLE_TRENDS_REQUEST_INTERVAL_MS=3000
GOOGLE_TRENDS_CACHE_TTL_MS=86400000

# GPT 评论分析（与 gpt.js 共用）
GPT_API_URL=
GPT_API_KEY=
GPT_MODEL=doubao
# GPT 联调测试可选：店铺截图 URL（test-gpt.js --live）
# GPT_TEST_IMAGE_A=
# GPT_TEST_IMAGE_B=
