DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=你的密码
DB_NAME=sop_system

# 首次部署（系统中尚无任何可登录账号时）自动创建的管理员
ADMIN_NAME=admin
ADMIN_PASSWORD=admin123

# JWT 登录凭证（生产环境务必修改为随机长字符串）
JWT_SECRET=请替换为随机长字符串
# JWT 有效期，例如 7d、12h、30d
JWT_TTL=7d

# 欧鹭评论下载 Cookie（复制 curl -b 引号内的整段，一行粘贴，不要换行）
# 格式：key1=value1; key2=value2; OALUR_SESSION=...; userId=...
# 含 $ 的 _ga 等字段建议用单引号包裹整段，避免被 dotenv 误解析
# OALUR_COOKIE='enterUrl=https://www.oalur.com/; clientId=xxx; OALUR_SESSION=xxx; userId=xxx; ...'
OALUR_COOKIE=

# Google Trends（通过 SearchAPI.io，与 ASIN 爬虫共用 token 池）
# 在「ASIN 爬虫」页面添加 SearchAPI token 后即可使用
GOOGLE_TRENDS_GEO=US
GOOGLE_TRENDS_HL=en-US
GOOGLE_TRENDS_TZ=360
GOOGLE_TRENDS_REQUEST_INTERVAL_MS=3000
GOOGLE_TRENDS_CACHE_TTL_MS=86400000
# SearchAPI TIMESERIES 单次最多 5 个关键词，批量时按此大小分批
GOOGLE_TRENDS_BATCH_SIZE=5

# ASIN 爬虫（SearchAPI）
SEARCHAPI_REQUEST_INTERVAL_MS=500
SEARCHAPI_TIMEOUT_MS=60000
SEARCHAPI_MAX_ASINS_PER_JOB=100

GPT_API_URL=
GPT_API_KEY=
GPT_MODEL=doubao
# GPT 联调测试可选：店铺截图 URL（test-gpt.js --live）
# GPT_TEST_IMAGE_A=
# GPT_TEST_IMAGE_B=
