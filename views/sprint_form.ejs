<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <%- include('head') %>
</head>
<body>
    <div class="app">
        <%- include('sidebar', { active: 'sprints' }) %>
        <main class="main-content">
            <a href="/sprints" class="back-link">← 返回冲刺项目</a>
            <div class="page-header">
                <h1><%= sprint && sprint.id ? '编辑冲刺项目' : '新建冲刺项目' %></h1>
                <div class="page-desc">字段校验严格，ASIN 唯一</div>
            </div>

            <% if (error) { %>
            <div style="background:#fef0f0; border:1px solid #fde2e2; color:#f56c6c; padding:12px 16px; border-radius:8px; margin-bottom:16px;">
                <%= error %>
            </div>
            <% } %>

            <form method="post" action="<%= sprint && sprint.id ? '/sprints/' + sprint.id : '/sprints' %>" style="max-width:980px;">
                <div class="module-card" style="margin-bottom:16px;">
                    <div class="module-header" style="cursor:default;">
                        <div class="module-name">基础信息</div>
                    </div>
                    <div class="module-body">
                        <div style="display:grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap:12px;">
                            <div>
                                <div style="font-size:13px; color:#606266; margin-bottom:6px;">ASIN *</div>
                                <input class="search-input" style="width:100%;" name="asin" value="<%= sprint ? sprint.asin : '' %>" <%= sprint && sprint.id ? 'readonly' : '' %> required>
                            </div>
                            <div>
                                <div style="font-size:13px; color:#606266; margin-bottom:6px;">负责人</div>
                                <select class="filter-select" style="width:100%;" name="owner_id">
                                    <option value="">未指定</option>
                                    <% (users || []).forEach(u => { %>
                                    <option value="<%= u.id %>" <%= sprint && String(sprint.owner_id||'') === String(u.id) ? 'selected' : '' %>><%= u.name %> (<%= u.role %>)</option>
                                    <% }) %>
                                </select>
                            </div>
                            <div>
                                <div style="font-size:13px; color:#606266; margin-bottom:6px;">状态</div>
                                <select class="filter-select" style="width:100%;" name="status" required>
                                    <% ['ACTIVE','MAINTENANCE','STOPPED'].forEach(s => { %>
                                    <option value="<%= s %>" <%= sprint && sprint.status === s ? 'selected' : '' %>><%= s %></option>
                                    <% }) %>
                                </select>
                            </div>
                            <div>
                                <div style="font-size:13px; color:#606266; margin-bottom:6px;">开始日期 *</div>
                                <input class="search-input" style="width:100%;" type="date" name="start_date" value="<%= sprint ? sprint.start_date : '' %>" required>
                            </div>
                            <div>
                                <div style="font-size:13px; color:#606266; margin-bottom:6px;">结束日期 *</div>
                                <input class="search-input" style="width:100%;" type="date" name="end_date" value="<%= sprint ? sprint.end_date : '' %>" required>
                            </div>
                            <div>
                                <div style="font-size:13px; color:#606266; margin-bottom:6px;">目标周期(天)</div>
                                <input class="search-input" style="width:100%;" type="number" name="target_cycle_days" min="0" step="any" value="<%= sprint && sprint.target_cycle_days !== null && sprint.target_cycle_days !== undefined ? sprint.target_cycle_days : 14 %>" required>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="module-card" style="margin-bottom:16px;">
                    <div class="module-header" style="cursor:default;">
                        <div class="module-name">业务目标</div>
                    </div>
                    <div class="module-body">
                        <div style="display:grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap:12px;">
                            <div>
                                <div style="font-size:13px; color:#606266; margin-bottom:6px;">当前日均单量</div>
                                <input class="search-input" style="width:100%;" type="number" name="current_daily_orders" min="0" step="any" value="<%= sprint && sprint.current_daily_orders !== null ? sprint.current_daily_orders : '' %>">
                            </div>
                            <div>
                                <div style="font-size:13px; color:#606266; margin-bottom:6px;">目标日均单量</div>
                                <input class="search-input" style="width:100%;" type="number" name="target_daily_orders" min="0" step="any" value="<%= sprint && sprint.target_daily_orders !== null ? sprint.target_daily_orders : '' %>">
                            </div>
                            <div>
                                <div style="font-size:13px; color:#606266; margin-bottom:6px;">当前排名</div>
                                <input class="search-input" style="width:100%;" type="number" name="current_rank" min="0" value="<%= sprint && sprint.current_rank !== null ? sprint.current_rank : '' %>">
                            </div>
                            <div>
                                <div style="font-size:13px; color:#606266; margin-bottom:6px;">目标排名</div>
                                <input class="search-input" style="width:100%;" type="number" name="target_rank" min="0" value="<%= sprint && sprint.target_rank !== null ? sprint.target_rank : '' %>">
                            </div>
                        </div>
                    </div>
                </div>

                <div class="module-card" style="margin-bottom:16px;">
                    <div class="module-header" style="cursor:default;">
                        <div class="module-name">财务风控</div>
                    </div>
                    <div class="module-body">
                        <div style="display:grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap:12px;">
                            <div>
                                <div style="font-size:13px; color:#606266; margin-bottom:6px;">推广期允许TACOS(%)</div>
                                <input class="search-input" style="width:100%;" type="number" step="0.01" name="promo_tacos_limit" min="0" value="<%= sprint && sprint.promo_tacos_limit !== null ? sprint.promo_tacos_limit : '' %>">
                            </div>
                            <div>
                                <div style="font-size:13px; color:#606266; margin-bottom:6px;">稳定期目标TACOS(%)</div>
                                <input class="search-input" style="width:100%;" type="number" step="0.01" name="stable_tacos_target" min="0" value="<%= sprint && sprint.stable_tacos_target !== null ? sprint.stable_tacos_target : '' %>">
                            </div>
                            <div>
                                <div style="font-size:13px; color:#606266; margin-bottom:6px;">7天最大亏损额度($)</div>
                                <input class="search-input" style="width:100%;" type="number" step="0.01" name="max_loss_7d" min="0" value="<%= sprint && sprint.max_loss_7d !== null ? sprint.max_loss_7d : '' %>">
                            </div>
                            <div>
                                <div style="font-size:13px; color:#606266; margin-bottom:6px;">ACOS上限(%)</div>
                                <input class="search-input" style="width:100%;" type="number" step="0.01" name="acos_limit" min="0" value="<%= sprint && sprint.acos_limit !== null ? sprint.acos_limit : '' %>">
                            </div>
                            <div>
                                <div style="font-size:13px; color:#606266; margin-bottom:6px;">利润率(%)</div>
                                <input class="search-input" style="width:100%;" type="number" step="0.01" name="profit_margin" min="0" value="<%= sprint && sprint.profit_margin !== null ? sprint.profit_margin : '' %>">
                            </div>
                        </div>
                    </div>
                </div>

                <div class="module-card" style="margin-bottom:16px;">
                    <div class="module-header" style="cursor:default;">
                        <div class="module-name">市场与供应链</div>
                    </div>
                    <div class="module-body">
                        <div style="display:grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap:12px;">
                            <div>
                                <div style="font-size:13px; color:#606266; margin-bottom:6px;">库存可支撑天数</div>
                                <input class="search-input" style="width:100%;" type="number" name="inventory_days" min="0" value="<%= sprint && sprint.inventory_days !== null ? sprint.inventory_days : '' %>">
                                <div style="font-size:12px; color:#909399; margin-top:4px;">低于 30 天会在列表标黄预警</div>
                            </div>
                            <div style="grid-column: span 2;">
                                <div style="font-size:13px; color:#606266; margin-bottom:6px;">竞品当前动作</div>
                                <input class="search-input" style="width:100%;" name="competitor_action" value="<%= sprint && sprint.competitor_action ? sprint.competitor_action : '' %>">
                            </div>
                            <div style="grid-column: span 3; display:flex; align-items:center; gap:8px; padding-top:4px;">
                                <input type="checkbox" name="page_ok" value="1" <%= sprint && Number(sprint.page_ok) === 1 ? 'checked' : '' %>>
                                <span style="font-size:14px;">页面是否达标</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="module-card" style="margin-bottom:16px;">
                    <div class="module-header" style="cursor:default;">
                        <div class="module-name">退出条件</div>
                    </div>
                    <div class="module-body">
                        <textarea class="sop-remark" name="exit_conditions" rows="4" placeholder="如：触发7天最大亏损额度 / 连续7天单量未达标"><%= sprint && sprint.exit_conditions ? sprint.exit_conditions : '' %></textarea>
                    </div>
                </div>

                <div style="display:flex; gap:12px; align-items:center;">
                    <button type="submit" class="btn-primary">保存</button>
                    <a class="btn-secondary" href="/sprints">取消</a>
                </div>
            </form>
        </main>
    </div>
</body>
</html>

