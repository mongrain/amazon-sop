<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <%- include('head') %>
</head>
<body>
    <div class="app">
        <%- include('sidebar', { active: 'knowledge' }) %>
        <main class="main-content">
            <div class="page-header">
                <div style="display:flex; justify-content:space-between; align-items:flex-start; gap:12px; flex-wrap:wrap;">
                    <div>
                        <h1>知识库</h1>
                        <div class="page-desc">编写与保存运营文档，支持直接粘贴 Word / Excel / 表格内容</div>
                        <form action="/knowledge" method="GET" class="search-form" style="margin-top:12px;">
                            <input
                                type="text"
                                name="keyword"
                                class="search-input"
                                placeholder="搜索标题或正文"
                                value="<%= keyword || '' %>"
                            >
                            <button type="submit" class="btn-secondary" style="padding:8px 16px;">搜索</button>
                            <% if (keyword) { %>
                                <a href="/knowledge" class="btn-secondary" style="padding:8px 16px;">重置</a>
                            <% } %>
                        </form>
                    </div>
                    <a href="/knowledge/new" class="btn-primary">+ 新建文档</a>
                </div>
            </div>

            <% function fmt(dt){ if(!dt) return '-'; const d = (dt instanceof Date) ? dt : new Date(dt); if (isNaN(d.getTime())) return String(dt); return d.toLocaleString('zh-CN', { hour12: false }); } %>

            <div class="table-container">
                <table class="product-table">
                    <thead>
                        <tr>
                            <th style="min-width:50px">#</th>
                            <th style="min-width:280px">标题</th>
                            <th style="min-width:360px">摘要</th>
                            <th style="min-width:180px">更新时间</th>
                            <th style="min-width:100px">操作</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (!docs || docs.length === 0) { %>
                        <tr>
                            <td colspan="5" style="text-align:center; padding:40px; color:#999;">
                                <%= keyword ? ('未找到包含“' + keyword + '”的文档') : '暂无文档，点击右上角「新建文档」开始编写' %>
                            </td>
                        </tr>
                        <% } %>

                        <% (docs || []).forEach((doc, idx) => { %>
                        <tr class="product-row" onclick="location.href='/knowledge/<%= doc.id %>'">
                            <td><%= (page - 1) * pageSize + idx + 1 %></td>
                            <td style="font-weight:500;"><%= doc.title %></td>
                            <td style="color:var(--text-secondary); max-width:480px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                                <%= doc.excerpt ? doc.excerpt.replace(/\s+/g, ' ').trim() : '-' %>
                            </td>
                            <td><%= fmt(doc.updated_at) %></td>
                            <td onclick="event.stopPropagation()">
                                <a href="/knowledge/<%= doc.id %>" style="color:var(--primary); text-decoration:none; font-size:13px;">打开</a>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>

            <% if (totalPages > 1) { %>
            <div style="display:flex; justify-content:center; gap:8px; margin-top:20px; align-items:center;">
                <% if (page > 1) { %>
                    <a href="/knowledge?page=<%= page - 1 %><%= keyword ? '&keyword=' + encodeURIComponent(keyword) : '' %>" class="btn-secondary" style="padding:6px 14px;">上一页</a>
                <% } %>
                <span style="font-size:13px; color:var(--text-secondary);">第 <%= page %> / <%= totalPages %> 页（共 <%= total %> 篇）</span>
                <% if (page < totalPages) { %>
                    <a href="/knowledge?page=<%= page + 1 %><%= keyword ? '&keyword=' + encodeURIComponent(keyword) : '' %>" class="btn-secondary" style="padding:6px 14px;">下一页</a>
                <% } %>
            </div>
            <% } %>
        </main>
    </div>
</body>
</html>
