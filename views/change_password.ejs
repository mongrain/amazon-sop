<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <%- include('head') %>
    <style>
        body { background: var(--bg); min-height: 100vh; display: flex; align-items: center; justify-content: center; }
        .login-card {
            width: 100%;
            max-width: 420px;
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.08);
            padding: 36px 32px;
        }
        .login-title { font-size: 22px; font-weight: 600; margin-bottom: 6px; }
        .login-desc { font-size: 13px; color: var(--text-secondary); margin-bottom: 24px; line-height: 1.6; }
        .login-field { margin-bottom: 16px; }
        .login-label { font-size: 13px; color: #606266; margin-bottom: 6px; display: block; }
        .login-input { width: 100%; box-sizing: border-box; }
        .login-error {
            background: #fef0f0;
            border: 1px solid #fde2e2;
            color: #f56c6c;
            padding: 10px 12px;
            border-radius: 8px;
            font-size: 13px;
            margin-bottom: 16px;
        }
        .login-warn {
            background: #fdf6ec;
            border: 1px solid #faecd8;
            color: #e6a23c;
            padding: 10px 12px;
            border-radius: 8px;
            font-size: 13px;
            margin-bottom: 16px;
        }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="login-title">修改密码</div>
        <% if (forced) { %>
            <div class="login-warn">首次登录须修改默认密码后才能使用系统</div>
        <% } else { %>
            <div class="login-desc">当前账号：<strong><%= currentUser.name %></strong></div>
        <% } %>

        <% if (error) { %>
            <div class="login-error"><%= error %></div>
        <% } %>

        <form method="post" action="/account/change-password">
            <div class="login-field">
                <label class="login-label" for="current_password">当前密码</label>
                <input class="search-input login-input" id="current_password" name="current_password" type="password" required autocomplete="current-password">
            </div>
            <div class="login-field">
                <label class="login-label" for="new_password">新密码</label>
                <input class="search-input login-input" id="new_password" name="new_password" type="password" required minlength="4" autocomplete="new-password">
            </div>
            <div class="login-field">
                <label class="login-label" for="confirm_password">确认新密码</label>
                <input class="search-input login-input" id="confirm_password" name="confirm_password" type="password" required minlength="4" autocomplete="new-password">
            </div>
            <button type="submit" class="btn-primary" style="width:100%; margin-top:8px;">保存并进入系统</button>
        </form>
        <% if (!forced) { %>
            <div style="margin-top:16px; text-align:center;">
                <a href="/dashboard" style="font-size:13px; color:var(--text-secondary);">取消</a>
            </div>
        <% } %>
    </div>
</body>
</html>
