<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <%- include('head') %>
</head>
<body>
    <div class="app">
        <%- include('sidebar', { active: 'sprints' }) %>
        <main class="main-content">
            <a href="/reviews?sprint_id=<%= review.sprint_id %>" class="back-link">← 返回周复盘列表</a>
            <div class="page-header">
                <h1>周复盘填写</h1>
                <div class="page-desc">ASIN：<code><%= review.asin %></code> · 周起始日：<%= review.week_start_date %></div>
            </div>

            <% if (error) { %>
            <div style="background:#fef0f0; border:1px solid #fde2e2; color:#f56c6c; padding:12px 16px; border-radius:8px; margin-bottom:16px;">
                <%= error %>
            </div>
            <% } %>

            <form method="post" action="/reviews/<%= review.id %>" style="max-width:900px;">
                <div class="module-card" style="margin-bottom:16px;">
                    <div class="module-header" style="cursor:default;">
                        <div class="module-name">核对</div>
                    </div>
                    <div class="module-body">
                        <div style="display:grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap:12px;">
                            <div>
                                <div style="font-size:13px; color:#606266; margin-bottom:6px;">本周实际最大亏损($) *</div>
                                <input class="search-input" style="width:100%;" type="number" step="0.01" name="actual_max_loss" value="<%= review.actual_max_loss === null ? '' : review.actual_max_loss %>" required>
                            </div>
                            <div>
                                <div style="font-size:13px; color:#606266; margin-bottom:6px;">当前实际TACOS(%) *</div>
                                <input class="search-input" style="width:100%;" type="number" step="0.01" name="actual_tacos" value="<%= review.actual_tacos === null ? '' : review.actual_tacos %>" required>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="module-card" style="margin-bottom:16px;">
                    <div class="module-header" style="cursor:default;">
                        <div class="module-name">评估与决策</div>
                    </div>
                    <div class="module-body">
                        <div style="display:grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap:12px;">
                            <div>
                                <div style="font-size:13px; color:#606266; margin-bottom:6px;">决策 *</div>
                                <select class="filter-select" style="width:100%;" name="decision" required>
                                    <option value="">请选择</option>
                                    <option value="CONTINUE" <%= review.decision === 'CONTINUE' ? 'selected' : '' %>>继续冲刺 (CONTINUE)</option>
                                    <option value="MAINTENANCE" <%= review.decision === 'MAINTENANCE' ? 'selected' : '' %>>转维护期 (MAINTENANCE)</option>
                                    <option value="STOPPED" <%= review.decision === 'STOPPED' ? 'selected' : '' %>>停止 (STOPPED)</option>
                                </select>
                                <div style="font-size:12px; color:#909399; margin-top:4px;">选择 MAINTENANCE/STOPPED 会同步更新项目状态</div>
                            </div>
                            <div>
                                <div style="font-size:13px; color:#606266; margin-bottom:6px;">复盘状态</div>
                                <select class="filter-select" style="width:100%;" name="status" required>
                                    <option value="PENDING" <%= review.status === 'PENDING' ? 'selected' : '' %>>PENDING</option>
                                    <option value="COMPLETED" <%= review.status === 'COMPLETED' ? 'selected' : '' %>>COMPLETED</option>
                                </select>
                            </div>
                        </div>
                        <div style="margin-top:12px;">
                            <div style="font-size:13px; color:#606266; margin-bottom:6px;">复盘结论记录 *</div>
                            <textarea class="sop-remark" name="summary" rows="6" required><%= review.summary || '' %></textarea>
                        </div>
                    </div>
                </div>

                <div style="display:flex; gap:12px; align-items:center;">
                    <button type="submit" class="btn-primary">保存</button>
                    <a class="btn-secondary" href="/reviews?sprint_id=<%= review.sprint_id %>">取消</a>
                </div>
            </form>
        </main>
    </div>
</body>
</html>

