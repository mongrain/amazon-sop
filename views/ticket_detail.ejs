<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <%- include('head') %>
</head>
<body>
    <div class="app">
        <%- include('sidebar', { active: 'tickets' }) %>
        <main class="main-content">
            <a href="/tickets" class="back-link">← 返回工单看板</a>
            <div class="page-header">
                <h1>工单详情</h1>
                <div class="page-desc">ID：<%= ticket.id %> · ASIN：<code><%= ticket.asin %></code> · 类型：<%= ticket.ticket_type %> · 等级：<%= ticket.severity || '-' %></div>
            </div>

            <% if (error) { %>
            <div style="background:#fef0f0; border:1px solid #fde2e2; color:#f56c6c; padding:12px 16px; border-radius:8px; margin-bottom:16px;">
                <%= error %>
            </div>
            <% } %>

            <div class="module-card" style="margin-bottom:16px;">
                <div class="module-header" style="cursor:default;">
                    <div class="module-name">当前状态</div>
                </div>
                <div class="module-body">
                    <div style="display:flex; gap:12px; align-items:center; flex-wrap:wrap;">
                        <span class="status-badge"><%= ticket.status %></span>
                        <span style="font-size:13px; color:#606266;">SLA截止：<%= ticket.sla_deadline || '-' %></span>
                        <span style="font-size:13px; color:#606266;">负责人：<%= ticket.owner_name || '-' %></span>
                        <span style="font-size:13px; color:#606266;">协作：<%= ticket.co_owner_name || '-' %></span>
                    </div>
                </div>
            </div>

            <div class="module-card" style="margin-bottom:16px;">
                <div class="module-header" style="cursor:default;">
                    <div class="module-name">触发原因</div>
                </div>
                <div class="module-body">
                    <div style="white-space:pre-wrap; font-size:13px; color:#303133;"><%= ticket.trigger_reason || '-' %></div>
                </div>
            </div>

            <div class="module-card" style="margin-bottom:16px;">
                <div class="module-header" style="cursor:default;">
                    <div class="module-name">动作区</div>
                </div>
                <div class="module-body">
                    <form method="post" action="/tickets/<%= ticket.id %>/assign" style="display:flex; gap:12px; align-items:end; flex-wrap:wrap; margin-bottom:16px;">
                        <div>
                            <div style="font-size:13px; color:#606266; margin-bottom:6px;">负责人</div>
                            <select class="filter-select" name="owner_id">
                                <option value="">未指定</option>
                                <% (users || []).forEach(u => { %>
                                <option value="<%= u.id %>" <%= String(ticket.owner_id||'') === String(u.id) ? 'selected' : '' %>><%= u.name %> (<%= u.role %>)</option>
                                <% }) %>
                            </select>
                        </div>
                        <div>
                            <div style="font-size:13px; color:#606266; margin-bottom:6px;">协作人</div>
                            <select class="filter-select" name="co_owner_id">
                                <option value="">未指定</option>
                                <% (users || []).forEach(u => { %>
                                <option value="<%= u.id %>" <%= String(ticket.co_owner_id||'') === String(u.id) ? 'selected' : '' %>><%= u.name %> (<%= u.role %>)</option>
                                <% }) %>
                            </select>
                        </div>
                        <button class="btn-secondary" type="submit">保存指派</button>
                    </form>

                    <form method="post" action="/tickets/<%= ticket.id %>/status" style="display:flex; gap:12px; align-items:end; flex-wrap:wrap; margin-bottom:16px;">
                        <div>
                            <div style="font-size:13px; color:#606266; margin-bottom:6px;">调整状态</div>
                            <select class="filter-select" name="status" required>
                                <% ['TODO','PENDING_DESIGN','WAITING_VERIFY','RESOLVED','FAILED'].forEach(s => { %>
                                <option value="<%= s %>" <%= ticket.status === s ? 'selected' : '' %>><%= s %></option>
                                <% }) %>
                            </select>
                        </div>
                        <button class="btn-secondary" type="submit">更新状态</button>
                    </form>

                    <div style="display:grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap:16px;">
                        <div style="border:1px solid #e4e7ed; border-radius:8px; padding:14px 16px;">
                            <div style="font-weight:700; margin-bottom:10px;">发起视觉需求</div>
                            <form method="post" action="/tickets/<%= ticket.id %>/design-request">
                                <textarea class="sop-remark" name="design_request" rows="5" placeholder="填写修改意见（提交后流转至 PENDING_DESIGN）" required><%= ticket.design_request || '' %></textarea>
                                <button class="btn-primary" type="submit" style="margin-top:10px;">提交视觉需求</button>
                            </form>
                        </div>

                        <div style="border:1px solid #e4e7ed; border-radius:8px; padding:14px 16px;">
                            <div style="font-weight:700; margin-bottom:10px;">视觉资产交付</div>
                            <form method="post" action="/tickets/<%= ticket.id %>/design-asset" enctype="multipart/form-data">
                                <input type="file" name="file" required>
                                <% if (ticket.design_asset_url) { %>
                                <div style="margin-top:10px; font-size:13px;">
                                    当前资产：<a href="<%= ticket.design_asset_url %>" target="_blank" style="color:#409eff;">打开</a>
                                </div>
                                <% } %>
                                <button class="btn-primary" type="submit" style="margin-top:10px;">上传并交付</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>

            <div class="module-card">
                <div class="module-header" style="cursor:default;">
                    <div class="module-name">举证式验收</div>
                </div>
                <div class="module-body">
                    <form method="post" action="/tickets/<%= ticket.id %>/verify" enctype="multipart/form-data" style="max-width:900px;">
                        <div style="display:flex; gap:12px; align-items:center; flex-wrap:wrap;">
                            <select class="filter-select" name="result" required>
                                <option value="">请选择验收结果</option>
                                <option value="RESOLVED">指标已达标 (RESOLVED)</option>
                                <option value="FAILED">未达标 (FAILED)</option>
                            </select>
                            <span style="font-size:13px; color:#606266;">必须填写最新指标值或上传截图</span>
                        </div>
                        <div style="margin-top:10px;">
                            <textarea class="sop-remark" name="verify_evidence" rows="4" placeholder="填写当前最新指标值 / 结论说明（或仅上传文件也可）"><%= ticket.verify_evidence || '' %></textarea>
                        </div>
                        <div style="margin-top:10px;">
                            <input type="file" name="file">
                            <% if (ticket.verify_file_url) { %>
                            <div style="margin-top:10px; font-size:13px;">
                                当前凭证：<a href="<%= ticket.verify_file_url %>" target="_blank" style="color:#409eff;">打开</a>
                            </div>
                            <% } %>
                        </div>
                        <button class="btn-primary" type="submit" style="margin-top:10px;">提交验收</button>
                    </form>
                </div>
            </div>
        </main>
    </div>
</body>
</html>

