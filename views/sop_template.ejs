<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <%- include('head', { title: 'SOP模板' }) %>
</head>
<body>
    <div class="app">
        <%- include('sidebar', { active: 'sop' }) %>
        <main class="main-content">
            <div class="page-header">
                <div style="display:flex; justify-content:space-between; align-items:flex-start;">
                    <div>
                        <h1>SOP 标准操作规范</h1>
                        <p class="page-desc">所有模块的操作流程与详细说明，供运营人员参考</p>
                    </div>
                    <button class="btn-primary" id="editModeBtn" onclick="toggleEditMode()">编辑模式</button>
                </div>
            </div>

            <div class="sop-grid">
                <% modules.forEach(module => {
                    const dataItems = module.sop_items.filter(i => i.is_data_column);
                    const actionItems = module.sop_items.filter(i => !i.is_data_column);
                %>
                <div class="sop-card" data-module-id="<%= module.id %>">
                    <div class="sop-card-header">
                        <h2 class="sop-card-title"><%= module.name %></h2>
                        <span class="sop-card-count"><%= dataItems.length %> 数据 · <%= actionItems.length %> 操作</span>
                    </div>
                    <div class="sop-card-body">
                        <!-- 数据字段 -->
                        <% if (dataItems.length > 0) { %>
                        <div class="sop-group">
                            <div class="sop-group-header sop-group-data-header" onclick="toggleGroup(this)">
                                <span class="sop-group-arrow">▼</span>
                                <span class="sop-group-badge type-data">数据字段</span>
                                <span class="sop-group-count"><%= dataItems.length %> 项</span>
                            </div>
                            <div class="sop-group-body">
                                <div class="sop-items-grid">
                                    <% dataItems.forEach(item => { %>
                                    <div class="sop-data-item" data-item-id="<%= item.id %>">
                                        <div class="sop-data-item-label">
                                            <span class="item-name-display"><%= item.name %></span>
                                            <span class="item-edit-controls" style="display:none;">
                                                <input type="text" class="item-edit-input" value="<%= item.name.replace(/"/g, '&quot;') %>">
                                            </span>
                                        </div>
                                        <div class="sop-data-item-sub">
                                            <code><%= item.table_ref || '' %></code>
                                        </div>
                                        <% if (item.instruction_text) { %>
                                        <div class="sop-data-item-desc"><%= item.instruction_text %></div>
                                        <% } %>
                                        <div class="sop-item-actions" style="display:none;">
                                            <button class="btn-icon btn-delete" onclick="deleteItem(<%= item.id %>, this)" title="删除">&times;</button>
                                        </div>
                                    </div>
                                    <% }) %>
                                </div>
                                <button class="btn-add-item" style="display:none;" onclick="addItem(<%= module.id %>, 'data', this)">+ 添加数据字段</button>
                            </div>
                        </div>
                        <% } %>

                        <!-- 操作项 -->
                        <% if (actionItems.length > 0) { %>
                        <div class="sop-group">
                            <div class="sop-group-header sop-group-action-header" onclick="toggleGroup(this)">
                                <span class="sop-group-arrow">▼</span>
                                <span class="sop-group-badge type-action">操作项</span>
                                <span class="sop-group-count"><%= actionItems.length %> 项</span>
                            </div>
                            <div class="sop-group-body">
                                <div class="sop-items-list">
                                    <% actionItems.forEach((item, idx) => { %>
                                    <div class="sop-action-item" data-item-id="<%= item.id %>">
                                        <div class="sop-action-item-header">
                                            <span class="sop-action-item-index">#<%= idx + 1 %></span>
                                            <span class="item-name-display"><%= item.name %></span>
                                            <span class="item-edit-controls" style="display:none;">
                                                <input type="text" class="item-edit-input" value="<%= item.name.replace(/"/g, '&quot;') %>">
                                                <button class="btn-sm btn-save-item" onclick="saveItemName(<%= item.id %>, this)">保存</button>
                                            </span>
                                        </div>
                                        <% if (item.instruction_text) { %>
                                        <div class="sop-action-item-instruction"><%= item.instruction_text %></div>
                                        <% } %>
                                        <% if (item.image_url) { %>
                                        <div class="sop-example-image sop-example-direct">
                                            <img src="<%= item.image_url %>" alt="示例图片" class="zoomable" onclick="openViewer(this.src)">
                                        </div>
                                        <% } %>
                                        <div class="sop-item-actions" style="display:none;">
                                            <label class="btn-upload-image" title="上传示例图片">
                                                上传图片
                                                <input type="file" accept="image/*" style="display:none;" onchange="uploadImage(<%= item.id %>, this)">
                                            </label>
                                            <button class="btn-icon btn-delete" onclick="deleteItem(<%= item.id %>, this)" title="删除">&times;</button>
                                        </div>
                                    </div>
                                    <% }) %>
                                </div>
                                <button class="btn-add-item" style="display:none;" onclick="addItem(<%= module.id %>, 'action', this)">+ 添加操作项</button>
                            </div>
                        </div>
                        <% } %>
                    </div>
                </div>
                <% }) %>
            </div>
        </main>
    </div>

    <script>
    let editMode = false;

    function toggleGroup(header) {
        const body = header.nextElementSibling;
        const arrow = header.querySelector('.sop-group-arrow');
        if (body.style.display === 'none') {
            body.style.display = 'block';
            arrow.textContent = '▼';
        } else {
            body.style.display = 'none';
            arrow.textContent = '▶';
        }
    }

    function toggleEditMode() {
        editMode = !editMode;
        const btn = document.getElementById('editModeBtn');
        btn.textContent = editMode ? '退出编辑' : '编辑模式';
        btn.classList.toggle('btn-danger', editMode);

        // Show/hide edit controls
        document.querySelectorAll('.sop-item-actions').forEach(el => {
            el.style.display = editMode ? 'inline-flex' : 'none';
        });
        document.querySelectorAll('.btn-add-item').forEach(el => {
            el.style.display = editMode ? 'inline-block' : 'none';
        });
        document.querySelectorAll('.item-edit-controls').forEach(el => {
            el.style.display = 'none';
        });
        document.querySelectorAll('.item-name-display').forEach(el => {
            el.style.display = editMode ? 'none' : 'inline';
        });
    }

    async function saveItemName(itemId, btn) {
        const el = btn.closest('.item-edit-controls');
        const input = el.querySelector('.item-edit-input');
        const newName = input.value.trim();
        if (!newName) return;

        try {
            const res = await fetch('/api/sop/item/' + itemId, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name: newName })
            });
            if (res.ok) location.reload();
        } catch (e) {
            console.error('Save failed:', e);
        }
    }

    async function deleteItem(itemId, btn) {
        if (!confirm('确认删除此操作项？')) return;
        try {
            const res = await fetch('/api/sop/item/' + itemId, { method: 'DELETE' });
            if (res.ok) {
                const card = btn.closest('.sop-card');
                const item = btn.closest('.sop-action-item, .sop-data-item');
                if (item) item.remove();
                // Refresh page to update counts
                setTimeout(() => location.reload(), 200);
            }
        } catch (e) {
            console.error('Delete failed:', e);
        }
    }

    async function addItem(moduleId, type, btn) {
        const name = prompt('请输入名称：');
        if (!name) return;
        const instruction = type === 'action' ? prompt('请输入操作说明（可选）：') || '' : '';

        try {
            const res = await fetch('/api/sop/item', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    module_id: moduleId,
                    name: name,
                    instruction_text: instruction,
                    is_data_column: type === 'data' ? 1 : 0
                })
            });
            if (res.ok) location.reload();
        } catch (e) {
            console.error('Add failed:', e);
        }
    }

    async function uploadImage(itemId, input) {
        if (!input.files[0]) return;
        const formData = new FormData();
        formData.append('image', input.files[0]);

        try {
            const res = await fetch('/api/sop/item/' + itemId + '/image', {
                method: 'POST',
                body: formData
            });
            const data = await res.json();
            if (res.ok) {
                location.reload();
            } else {
                alert(data.error || '上传失败');
            }
        } catch (e) {
            alert('上传失败: ' + e.message);
        }
    }
    </script>
</body>
</html>
