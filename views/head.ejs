<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title + ' - ' : '' %>Amazon 运营SOP管理系统</title>
    <script src="https://unpkg.com/htmx.org@1.9.10"></script>
    <link rel="stylesheet" href="/style.css">
    <style>
    .zoomable{cursor:zoom-in}
    </style>
    <script>
    let viewerScale = 1, viewerX = 0, viewerY = 0, isDragging = false, dragStartX, dragStartY;
    function openViewer(src) {
        viewerScale = 1; viewerX = 0; viewerY = 0;
        const v = document.getElementById('imageViewer');
        const img = document.getElementById('viewerImg');
        img.src = src;
        img.style.transform = 'scale(1) translate(0px,0px)';
        v.style.display = 'flex';
    }
    function closeViewer() {
        document.getElementById('imageViewer').style.display = 'none';
    }
    document.addEventListener('DOMContentLoaded', function() {
        var container = document.querySelector('.viewer-container');
        if (!container) return;
        var img = document.getElementById('viewerImg');
        container.addEventListener('wheel', function(e) {
            e.preventDefault();
            var delta = e.deltaY > 0 ? -0.15 : 0.15;
            viewerScale = Math.max(0.5, Math.min(8, viewerScale + delta));
            img.style.transform = 'scale(' + viewerScale + ') translate(' + viewerX + 'px,' + viewerY + 'px)';
        }, { passive: false });
        container.addEventListener('mousedown', function(e) {
            if (viewerScale <= 1) return;
            isDragging = true;
            dragStartX = e.clientX - viewerX * viewerScale;
            dragStartY = e.clientY - viewerY * viewerScale;
            img.style.cursor = 'grabbing';
        });
        document.addEventListener('mousemove', function(e) {
            if (!isDragging) return;
            viewerX = (e.clientX - dragStartX) / viewerScale;
            viewerY = (e.clientY - dragStartY) / viewerScale;
            img.style.transform = 'scale(' + viewerScale + ') translate(' + viewerX + 'px,' + viewerY + 'px)';
        });
        document.addEventListener('mouseup', function() {
            isDragging = false;
            if (img) img.style.cursor = 'default';
        });
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') closeViewer();
        });
    });
    </script>
</head>
