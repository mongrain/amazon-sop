<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <%- include('head', { title: product.name || product.asin }) %>
</head>
<body>
    <div class="app">
        <%- include('sidebar', { active: '' }) %>
        <main class="main-content">
            <div class="page-header">
                <div class="flex justify-between items-start">
                    <div>
                        <a href="/dashboard" class="back-link">&larr; 返回看板</a>
                        <h1><%= product.name || product.asin %></h1>
                        <div class="product-meta mt-1.5">
                            <span class="meta-item">ASIN: <code><%= product.asin %></code></span>
                            <% if (product.category) { %><span class="meta-item">分类: <%= product.category %></span><% } %>
                            <% if (product.seq) { %><span class="meta-item">序号: <%= product.seq %></span><% } %>
                            <span class="meta-item">状态:
                                <select class="status-select px-2 py-0.5 text-xs" onchange="updateProductStatus('<%= product.asin %>', this.value)">
                                    <% ['待处理', '进行中', '已完成', '跳过'].forEach(s => { %>
                                    <option value="<%= s %>" <%= product.status === s ? 'selected' : '' %>><%= s %></option>
                                    <% }) %>
                                </select>
                            </span>
                        </div>
                    </div>
                    <div class="flex items-center gap-2">
                        <div class="progress-bar min-w-[140px]">
                            <div class="progress-fill" id="overall-progress-fill" style="width: <%= Math.round(product.overall_progress * 100) %>%"></div>
                            <span class="progress-text" id="overall-progress-text"><%= Math.round(product.overall_progress * 100) %>%</span>
                        </div>
                        <button class="btn-secondary px-4 py-1.5 text-[13px]" onclick="openVersionModal()">版本管理</button>
                        <button class="btn-primary px-4 py-1.5 text-[13px]" onclick="openEditModal()">编辑产品</button>
                        <button class="btn-danger px-4 py-1.5" onclick="deleteProduct()">删除产品</button>
                    </div>
                </div>
            </div>

            <div class="sop-grid">
                <% modules.forEach(module => { %>
                <% const mp = moduleProgress[module.id] || { completed: 0, total: 0, percentage: 0 }; %>
                <% const dataItems = module.sop_items.filter(i => i.is_data_column); %>
                <% const actionItems = module.sop_items.filter(i => !i.is_data_column); %>
                <div class="sop-card">
                    <div class="sop-card-header">
                        <h2 class="sop-card-title"><%= module.name %></h2>
                        <span class="sop-card-count"><%= mp.completed %>/<%= mp.total %></span>
                    </div>
                    <div class="pt-2 px-[18px] pb-0 bg-[#fafafa] border-b border-[#e4e7ed]">
                        <div class="progress-bar min-w-full h-4">
                            <div class="progress-fill" style="width: <%= Math.round(mp.percentage * 100) %>%;"></div>
                            <span class="progress-text text-[10px]"><%= Math.round(mp.percentage * 100) %>%</span>
                        </div>
                    </div>
                    <div class="sop-card-body">
                        <!-- 数据字段 -->
                        <% if (dataItems.length > 0) { %>
                        <div class="sop-group">
                            <div class="sop-group-header sop-group-data-header" onclick="toggleGroup(this)">
                                <span class="sop-group-arrow">▼</span>
                                <span class="sop-group-badge type-data">数据字段</span>
                                <span class="sop-group-count"><%= dataItems.length %> 项</span>
                            </div>
                            <div class="sop-group-body">
                                <div class="sop-items-grid">
                                    <% dataItems.forEach(item => { %>
                                    <% const rec = recordMap[item.id] || { id: '', status: '待处理', remark: '', updated_at: null }; %>
                                    <div class="sop-data-item sop-data-field" data-item-id="<%= item.id %>">
                                        <div class="sop-data-item-label"><%= item.name %></div>
                                        <% if (item.table_ref === 'product_sop_records.updated_at') { %>
                                        <span class="sop-field-time" title="随保存自动更新"><%= rec.updated_at ? new Date(rec.updated_at).toLocaleString('zh-CN', {year:'numeric',month:'2-digit',day:'2-digit',hour:'2-digit',minute:'2-digit',second:'2-digit',hour12:false}).replace(/\//g, '-') : '暂无' %></span>
                                        <% } else { %>
                                        <textarea class="sop-field-textarea" rows="2"
                                                  placeholder="填写..."
                                                  onblur="updateRecord('<%= rec.id %>', 'remark', this.value)"><%= rec.remark || '' %></textarea>
                                        <% } %>
                                    </div>
                                    <% }) %>
                                </div>
                            </div>
                        </div>
                        <% } %>

                        <!-- 操作项 -->
                        <% if (actionItems.length > 0) { %>
                        <div class="sop-group">
                            <div class="sop-group-header sop-group-action-header" onclick="toggleGroup(this)">
                                <span class="sop-group-arrow">▼</span>
                                <span class="sop-group-badge type-action">操作项</span>
                                <span class="sop-group-count"><%= actionItems.length %> 项</span>
                            </div>
                            <div class="sop-group-body">
                                <div class="sop-items-list">
                                    <% actionItems.forEach((item, idx) => { %>
                                    <% const rec = recordMap[item.id] || { id: '', status: '待处理', remark: '', image_url: '' }; %>
                                    <div class="sop-action-item" id="sop-item-<%= item.id %>">
                                        <div class="sop-action-item-header">
                                            <span class="sop-action-item-index">#<%= idx + 1 %></span>
                                            <span class="sop-action-item-name"><%= item.name %></span>
                                            <select class="sop-status-select ml-auto" onchange="updateRecord(<%= rec.id %>, 'status', this.value)">
                                                <% ['待处理', '进行中', '已完成', '跳过'].forEach(s => { %>
                                                <option value="<%= s %>" <%= rec.status === s ? 'selected' : '' %>><%= s %></option>
                                                <% }) %>
                                            </select>
                                        </div>
                                        <% if (item.instruction_text) { %>
                                        <div class="sop-action-item-instruction cursor-pointer whitespace-pre-wrap line-clamp-3" onclick="this.classList.toggle('line-clamp-3'); this.classList.toggle('line-clamp-none')"><%= item.instruction_text %></div>
                                        <% } %>
                                        <!-- 模板示例图片：默认？号，hover显示 -->
                                        <% if (item.image_url) { %>
                                        <div class="sop-example-image sop-example-thumb">
                                            <img src="<%= item.image_url %>" alt="示例图片" class="zoomable" onclick="openViewer(this.src)">
                                        </div>
                                        <% } %>
                                        <!-- 用户上传的操作图片 -->
                                        <% if (rec.image_url) { %>
                                        <div class="sop-action-uploaded-images">
                                            <% let uploadedUrls = []; %>
                                            <% try { uploadedUrls = JSON.parse(rec.image_url); } catch(e) { uploadedUrls = [rec.image_url]; } %>
                                            <% uploadedUrls.forEach(function(url) { %>
                                            <div class="sop-action-uploaded-image">
                                                <img src="<%= url %>" alt="操作图片" class="zoomable" onclick="openViewer(this.src)">
                                                <button class="btn-icon-del" onclick="deleteActionImage(<%= rec.id %>, '<%= url %>')" title="删除图片">&times;</button>
                                            </div>
                                            <% }) %>
                                        </div>
                                        <% } %>
                                        <div class="sop-action-footer">
                                            <label class="btn-upload-action" title="上传操作截图">
                                                📷 上传截图
                                                <input type="file" accept="image/*" class="hidden" onchange="uploadActionImage(<%= rec.id %>, this)">
                                            </label>
                                            <textarea class="sop-remark"
                                                      placeholder="备注..."
                                                      onblur="updateRecord(<%= rec.id %>, 'remark', this.value)"
                                                      rows="1"><%= rec.remark || '' %></textarea>
                                        </div>
                                    </div>
                                    <% }) %>
                                </div>
                            </div>
                        </div>
                        <% } %>
                    </div>
                </div>
                <% }) %>
            </div>
        </main>
    </div>

    <!-- Edit Product Modal -->
    <div class="modal-overlay" id="editModal" onclick="if(event.target===this)this.classList.remove('active')">
        <div class="modal-box">
            <div class="modal-header">
                <h3>编辑产品</h3>
                <button class="modal-close" onclick="document.getElementById('editModal').classList.remove('active')">&times;</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>ASIN（不可修改）</label>
                    <input type="text" id="editAsin" class="form-input bg-[#f5f5f5]" readonly>
                </div>
                <div class="form-group">
                    <label>产品名称</label>
                    <input type="text" id="editName" class="form-input">
                </div>
                <div class="form-group">
                    <label>分类</label>
                    <input type="text" id="editCategory" class="form-input">
                </div>
                <div class="modal-error" id="editError"></div>
            </div>
            <div class="modal-footer">
                <button class="btn-cancel" onclick="document.getElementById('editModal').classList.remove('active')">取消</button>
                <button class="btn-submit" onclick="saveEditProduct()">保存修改</button>
            </div>
        </div>
    </div>

    <!-- Version Management Modal -->
    <div class="modal-overlay" id="versionModal" onclick="if(event.target===this)closeVersionModal()">
        <div class="modal-box w-[560px] max-h-[80vh] flex flex-col">
            <div class="modal-header">
                <h3>版本管理</h3>
                <button class="modal-close" onclick="closeVersionModal()">&times;</button>
            </div>
            <div class="modal-body overflow-y-auto flex-1">
                <div class="flex items-end gap-2 mb-4 p-3 bg-[#f5f7fa] rounded-md">
                    <div class="flex-1">
                        <label class="block text-[13px] font-semibold mb-1.5">版本名称（可选）</label>
                        <input type="text" id="newVersionName" class="form-input" placeholder="例如：初次优化、第二轮调整">
                    </div>
                    <button class="btn-submit" onclick="createVersion()">生成新版本</button>
                </div>
                <div class="modal-error" id="versionError"></div>
                <div id="versionList" class="flex flex-col gap-2">
                    <div class="text-center py-5 text-[#999]">加载中...</div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-cancel" onclick="closeVersionModal()">关闭</button>
            </div>
        </div>
    </div>

    <script>
    function toggleGroup(header) {
        const body = header.nextElementSibling;
        const arrow = header.querySelector('.sop-group-arrow');
        if (body.classList.contains('hidden')) {
            body.classList.remove('hidden');
            arrow.textContent = '▼';
        } else {
            body.classList.add('hidden');
            arrow.textContent = '▶';
        }
    }

    function updateRecord(recordId, field, value) {
        const rid = String(recordId);
        if (!rid || rid === 'undefined' || rid === 'null') return;
        const data = {};
        data[field] = value;
        fetch('/api/record/' + rid, {
            method: 'PATCH',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify(data)
        }).then(r => {
            if (r.ok) updateTimeDisplays();
        }).catch(e => console.error('Update failed:', e));
        refreshProgress();
    }

    function updateTimeDisplays() {
        const now = new Date();
        const y = now.getFullYear();
        const M = String(now.getMonth() + 1).padStart(2, '0');
        const D = String(now.getDate()).padStart(2, '0');
        const h = String(now.getHours()).padStart(2, '0');
        const m = String(now.getMinutes()).padStart(2, '0');
        const s = String(now.getSeconds()).padStart(2, '0');
        const timeStr = `${y}-${M}-${D} ${h}:${m}:${s}`;
        document.querySelectorAll('.sop-field-time').forEach(el => {
            el.textContent = timeStr;
        });
    }

    async function uploadActionImage(recordId, input) {
        if (!input.files[0] || !recordId) return;
        const formData = new FormData();
        formData.append('image', input.files[0]);
        try {
            const res = await fetch('/api/record/' + recordId + '/image', {
                method: 'POST',
                body: formData
            });
            const data = await res.json();
            if (res.ok) {
                location.reload();
            } else {
                alert(data.error || '上传失败');
            }
        } catch (e) {
            alert('上传失败: ' + e.message);
        }
    }

    async function deleteActionImage(recordId, imageUrl) {
        if (!confirm('确认删除此图片？')) return;
        try {
            const res = await fetch('/api/record/' + recordId + '/image/delete', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ image_url: imageUrl })
            });
            if (res.ok) location.reload();
        } catch (e) {
            alert('删除失败');
        }
    }

    function updateProductStatus(asin, status) {
        fetch('/api/product/' + asin, {
            method: 'PATCH',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({status: status})
        }).catch(e => console.error('Status update failed:', e));
    }

    function refreshProgress() {
        const selects = document.querySelectorAll('.sop-status-select');
        let completed = 0, total = 0;
        selects.forEach(sel => {
            total++;
            if (sel.value === '已完成') completed++;
        });
        const pct = total > 0 ? Math.round(completed / total * 100) : 0;
        const fill = document.getElementById('overall-progress-fill');
        const txt = document.getElementById('overall-progress-text');
        if (fill) fill.style.width = pct + '%';
        if (txt) txt.textContent = pct + '%';
    }

    function openEditModal() {
        document.getElementById('editAsin').value = '<%= product.asin %>';
        document.getElementById('editName').value = '<%= (product.name || '').replace(/'/g, "\\'") %>';
        document.getElementById('editCategory').value = '<%= (product.category || '').replace(/'/g, "\\'") %>';
        document.getElementById('editError').textContent = '';
        document.getElementById('editModal').classList.add('active');
    }

    async function saveEditProduct() {
        const asin = document.getElementById('editAsin').value.trim();
        const name = document.getElementById('editName').value.trim();
        const category = document.getElementById('editCategory').value.trim();
        const errEl = document.getElementById('editError');

        try {
            const res = await fetch('/api/product/' + asin, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name, category })
            });
            const data = await res.json();
            if (res.ok) {
                location.reload();
            } else {
                errEl.textContent = data.error || '保存失败';
            }
        } catch (e) {
            errEl.textContent = '网络错误: ' + e.message;
        }
    }

    async function deleteProduct() {
        if (!confirm('确认删除该产品？所有操作记录将一并删除。')) return;
        try {
            const res = await fetch('/api/product/<%= product.asin %>/delete', { method: 'POST' });
            const data = await res.json();
            if (res.ok) {
                window.location.href = '/dashboard';
            } else {
                alert('删除失败: ' + (data.error || '未知错误'));
            }
        } catch (e) {
            alert('网络错误: ' + e.message);
        }
    }

    // ========== Version Management ==========
    function openVersionModal() {
        document.getElementById('versionModal').classList.add('active');
        document.getElementById('versionError').textContent = '';
        document.getElementById('newVersionName').value = '';
        loadVersions();
    }
    function closeVersionModal() {
        document.getElementById('versionModal').classList.remove('active');
    }
    function fmtTime(t) {
        if (!t) return '—';
        const d = new Date(t);
        const y = d.getFullYear();
        const M = String(d.getMonth() + 1).padStart(2, '0');
        const D = String(d.getDate()).padStart(2, '0');
        const h = String(d.getHours()).padStart(2, '0');
        const m = String(d.getMinutes()).padStart(2, '0');
        return `${y}-${M}-${D} ${h}:${m}`;
    }
    async function loadVersions() {
        const list = document.getElementById('versionList');
        list.innerHTML = '<div class="text-center py-5 text-[#999]">加载中...</div>';
        try {
            const res = await fetch('/api/product/<%= product.asin %>/versions');
            const data = await res.json();
            if (!res.ok) {
                list.innerHTML = '<div class="text-center py-5 text-[#f56c6c]">' + (data.error || '加载失败') + '</div>';
                return;
            }
            if (!data.versions || data.versions.length === 0) {
                list.innerHTML = '<div class="text-center py-7 text-[#999]">暂无版本，点击"生成新版本"创建第一个版本</div>';
                return;
            }
            list.innerHTML = data.versions.map(v => `
                <div class="flex items-center gap-2.5 py-3 px-3.5 bg-[#fafafa] border border-[#e4e7ed] rounded-lg">
                    <span class="inline-block min-w-[36px] px-2 py-0.5 text-center bg-[#409eff] text-white font-semibold rounded text-xs">V${v.version_number}</span>
                    <div class="flex-1 min-w-0">
                        <div class="text-[14px] font-semibold text-[#303133] mb-0.5">${v.version_name ? escapeHtml(v.version_name) : '<span class="text-[#909399] font-normal">(未命名)</span>'}</div>
                        <div class="text-xs text-[#909399]">创建：${fmtTime(v.created_at)}${v.updated_at && v.updated_at !== v.created_at ? '　|　最后修改：' + fmtTime(v.updated_at) : ''}</div>
                    </div>
                    <a href="/product/<%= product.asin %>/version/${v.id}" class="btn-sm bg-[#409eff] text-white border-[#409eff]">查看/编辑</a>
                    <button class="btn-icon w-7 h-7" onclick="deleteVersion(${v.id})" title="删除版本">×</button>
                </div>
            `).join('');
        } catch (e) {
            list.innerHTML = '<div class="text-center py-5 text-[#f56c6c]">加载失败: ' + e.message + '</div>';
        }
    }
    function escapeHtml(s) {
        if (s == null) return '';
        return String(s).replace(/[&<>"']/g, ch => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[ch]));
    }
    async function createVersion() {
        const errEl = document.getElementById('versionError');
        errEl.textContent = '';
        const versionName = document.getElementById('newVersionName').value.trim();
        try {
            const res = await fetch('/api/product/<%= product.asin %>/version', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ version_name: versionName || null })
            });
            const data = await res.json();
            if (!res.ok) {
                errEl.textContent = data.error || '生成失败';
                return;
            }
            document.getElementById('newVersionName').value = '';
            loadVersions();
        } catch (e) {
            errEl.textContent = '网络错误: ' + e.message;
        }
    }
    async function deleteVersion(id) {
        if (!confirm('确认删除此版本？此操作不可恢复。')) return;
        try {
            const res = await fetch('/api/version/' + id, { method: 'DELETE' });
            if (res.ok) {
                loadVersions();
            } else {
                const data = await res.json();
                alert('删除失败: ' + (data.error || '未知错误'));
            }
        } catch (e) {
            alert('网络错误: ' + e.message);
        }
    }
    </script>
</body>
</html>
