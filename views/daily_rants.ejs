<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <%- include('head') %>
</head>
<body>
    <div class="app">
        <%- include('sidebar', { active: 'daily_rants' }) %>
        <main class="main-content">
            <div class="page-header">
                <div style="display:flex; justify-content:space-between; align-items:flex-start; gap:12px; flex-wrap:wrap;">
                    <div>
                        <h1>每日吐槽</h1>
                        <div class="page-desc"><%= (typeof isManager !== 'undefined' && isManager) ? '记录每日心声，支持 Markdown；管理员可查看全员吐槽' : '记录每日心声，支持 Markdown；仅显示你自己的吐槽' %></div>
                        <form action="/daily-rants" method="GET" class="search-form" style="margin-top:12px;">
                            <input
                                type="text"
                                name="keyword"
                                class="search-input"
                                placeholder="<%= (typeof isManager !== 'undefined' && isManager) ? '搜索内容或作者' : '搜索内容' %>"
                                value="<%= keyword || '' %>"
                            >
                            <button type="submit" class="btn-secondary" style="padding:8px 16px;">搜索</button>
                            <% if (keyword) { %>
                                <a href="/daily-rants" class="btn-secondary" style="padding:8px 16px;">重置</a>
                            <% } %>
                        </form>
                    </div>
                    <a href="/daily-rants/new" class="btn-primary">+ 写吐槽</a>
                </div>
            </div>

            <% function fmt(dt){ if(!dt) return '-'; const d = (dt instanceof Date) ? dt : new Date(dt); if (isNaN(d.getTime())) return String(dt); return d.toLocaleString('zh-CN', { hour12: false }); } %>
            <% function fmtDate(dt){
                if(!dt) return '-';
                if (typeof dt === 'string' && /^\d{4}-\d{2}-\d{2}/.test(dt)) return dt.slice(0, 10);
                const d = (dt instanceof Date) ? dt : new Date(dt);
                if (isNaN(d.getTime())) return String(dt);
                return d.toLocaleDateString('zh-CN');
            } %>
            <% function excerpt(text, len){
                const plain = String(text || '').replace(/[#>*`\[\]()!|-]/g, ' ').replace(/\s+/g, ' ').trim();
                if (!plain) return '-';
                return plain.length > len ? plain.slice(0, len) + '…' : plain;
            } %>

            <div class="table-container">
                <table class="product-table">
                    <thead>
                        <tr>
                            <th style="min-width:50px">#</th>
                            <th style="min-width:110px">日期</th>
                            <th style="min-width:100px">作者</th>
                            <th style="min-width:360px">摘要</th>
                            <th style="min-width:160px">更新时间</th>
                            <th style="min-width:80px">操作</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (!rants || rants.length === 0) { %>
                        <tr>
                            <td colspan="6" style="text-align:center; padding:40px; color:#999;">
                                <%= keyword ? ('未找到相关吐槽') : '暂无吐槽，点击右上角「写吐槽」开始' %>
                            </td>
                        </tr>
                        <% } %>

                        <% (rants || []).forEach((rant, idx) => { %>
                        <tr class="product-row" onclick="location.href='/daily-rants/<%= rant.id %>'">
                            <td><%= (page - 1) * pageSize + idx + 1 %></td>
                            <td><%= fmtDate(rant.rant_date) %></td>
                            <td>
                                <span style="font-weight:500;"><%= rant.author_name %></span>
                                <% if (currentUser && rant.user_id === currentUser.id) { %>
                                    <span style="font-size:11px; color:var(--primary); margin-left:4px;">我</span>
                                <% } %>
                            </td>
                            <td style="color:var(--text-secondary); max-width:480px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                                <%= excerpt(rant.content, 80) %>
                            </td>
                            <td><%= fmt(rant.updated_at) %></td>
                            <td onclick="event.stopPropagation()">
                                <a href="/daily-rants/<%= rant.id %>" style="color:var(--primary); text-decoration:none; font-size:13px;">查看</a>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>

            <% if (totalPages > 1) { %>
            <div style="display:flex; justify-content:center; gap:8px; margin-top:20px; align-items:center;">
                <% if (page > 1) { %>
                    <a href="/daily-rants?page=<%= page - 1 %><%= keyword ? '&keyword=' + encodeURIComponent(keyword) : '' %>" class="btn-secondary" style="padding:6px 14px;">上一页</a>
                <% } %>
                <span style="font-size:13px; color:var(--text-secondary);">第 <%= page %> / <%= totalPages %> 页（共 <%= total %> 条）</span>
                <% if (page < totalPages) { %>
                    <a href="/daily-rants?page=<%= page + 1 %><%= keyword ? '&keyword=' + encodeURIComponent(keyword) : '' %>" class="btn-secondary" style="padding:6px 14px;">下一页</a>
                <% } %>
            </div>
            <% } %>
        </main>
    </div>
</body>
</html>
