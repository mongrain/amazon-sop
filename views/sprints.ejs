<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <%- include('head') %>
</head>
<body>
    <div class="app">
        <%- include('sidebar', { active: 'sprints' }) %>
        <main class="main-content">
            <div class="page-header">
                <div style="display:flex; justify-content:space-between; align-items:flex-start; gap:12px;">
                    <div>
                        <h1>冲刺项目</h1>
                        <div class="page-desc">立项 -> 数据追踪 -> 规则诊断 -> 工单流转 -> 举证验收</div>
                    </div>
                    <a class="btn-primary" href="/sprints/new">+ 新建冲刺项目</a>
                </div>
            </div>

            <div class="table-container">
                <table class="product-table">
                    <thead>
                        <tr>
                            <th style="min-width:50px">ID</th>
                            <th style="min-width:120px">ASIN</th>
                            <th style="min-width:120px">负责人</th>
                            <th style="min-width:120px">状态</th>
                            <th style="min-width:160px">周期</th>
                            <th style="min-width:140px">库存天数</th>
                            <th style="min-width:140px">利润率%</th>
                            <th style="min-width:160px">亏损额度(7D)</th>
                            <th style="min-width:160px">ACOS上限</th>
                            <th style="min-width:200px">操作</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (!sprints || sprints.length === 0) { %>
                        <tr>
                            <td colspan="10" style="text-align:center; padding:40px; color:#999;">暂无冲刺项目</td>
                        </tr>
                        <% } %>
                        <% (sprints || []).forEach(sp => { %>
                        <tr>
                            <td><%= sp.id %></td>
                            <td><code><%= sp.asin %></code></td>
                            <td><%= sp.owner_name || '-' %></td>
                            <td><span class="status-badge"><%= sp.status %></span></td>
                            <td><%= sp.start_date %> ~ <%= sp.end_date %></td>
                            <td style="<%= sp.inventory_days !== null && sp.inventory_days < 30 ? 'color:#e6a23c; font-weight:700;' : '' %>"><%= sp.inventory_days === null ? '-' : sp.inventory_days %></td>
                            <td><%= sp.profit_margin === null ? '-' : sp.profit_margin %></td>
                            <td><%= sp.max_loss_7d === null ? '-' : sp.max_loss_7d %></td>
                            <td><%= sp.acos_limit === null ? '-' : sp.acos_limit %></td>
                            <td>
                                <a class="btn-sm" href="/sprints/<%= sp.id %>">编辑</a>
                                <a class="btn-sm" href="/tickets?asin=<%= sp.asin %>">查看工单</a>
                                <a class="btn-sm" href="/reviews?sprint_id=<%= sp.id %>">周复盘</a>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </main>
    </div>
</body>
</html>

